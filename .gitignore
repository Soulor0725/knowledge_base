# 数据库文件
*.db
knowledge_base.db

# 上传的图片（可选，若希望保留则删除此行）
static/uploads/*

# 临时文件
__pycache__/
*.pyc

# 环境变量文件（若有）
.env

# 忽略 agent / AI 辅助工具生成的目录和配置（不随项目启动一起推送）
.mimocode/
.copilot*
.agent*

# 忽略测试脚本（非启动所需）
/test_*.py
/test*.py
/Test_Team/

# 编辑器配置
.vscode/

# 忽略 CodeBuddy 指南（非启动所需）
CODEBUDDY.md

# 备份与临时脚本（不入库）
*.bak
fix_*.py
_*.py
.patch_*.ps1
